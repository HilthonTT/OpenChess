# Workspace-wide env. Bun injects this file into every workspace script BEFORE
# packages/server loads its own .env, and dotenv never overwrites an existing
# variable — so anything set here wins over packages/server/.env. Keep the two
# in sync or define a variable in only one place.
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# PostgreSQL connection string (Prisma + pg adapter).
DATABASE_URL=postgresql://user:password@localhost:5432/openchess

# Comma-separated CORS allowlist, used in production.
ALLOWED_ORIGINS=

# The public origin this API is served on. Used to build the URL Polar returns
# the customer to after checkout. Defaults to http://localhost:$PORT outside
# production; required when NODE_ENV=production.
PUBLIC_BASE_URL=

CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# The client_id of our own Clerk OAuth application. Required in production.
CLERK_OAUTH_CLIENT_ID=

# The CLI reads these to run the sign-in flow.
CLERK_FRONTEND_API=
API_URL=http://localhost:3000/api

# Leave blank to run without Sentry.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1

# Get these from the Polar dashboard for the environment named by POLAR_SERVER —
# sandbox and production have separate tokens and products, and IDs from one do
# not resolve in the other.
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
# 'sandbox' (play money) or 'production' (real charges). Must be 'production'
# when NODE_ENV=production, or the server refuses to start.
POLAR_SERVER=sandbox

# Local development runs against the Inngest dev server (`bun run inngest`).
# In production INNGEST_DEV must be UNSET and INNGEST_SIGNING_KEY set, or the
# server refuses to start: dev mode disables signature checks on /api/inngest.
INNGEST_DEV=1
INNGEST_SIGNING_KEY=

# Optional pair backing the read cache; leave both blank to run uncached.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
