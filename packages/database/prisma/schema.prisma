// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  username    String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Source of truth for progression. `level` is derived from `experience` by
  // server logic and stored so the leaderboard can sort without recomputing it.
  experience Int @default(0)
  level      Int @default(1)

  // Cached balance. The CoinTransaction ledger is authoritative; this is written
  // in the same transaction as the ledger row.
  coins Int @default(0)

  equippedTitleId String?
  equippedTitle   Title?  @relation("EquippedTitle", fields: [equippedTitleId], references: [id], onDelete: SetNull)

  stats        UserStats?
  achievements UserAchievement[]
  titles       UserTitle[]
  transactions CoinTransaction[]
  gamesAsWhite Game[]            @relation("WhitePlayer")
  gamesAsBlack Game[]            @relation("BlackPlayer")

  puzzleAttempts      PuzzleAttempt[]
  challengesSent      Challenge[]     @relation("Challenger")
  challengesReceived  Challenge[]     @relation("Challenged")

  @@index([level(sort: Desc), experience(sort: Desc)])
}

model UserStats {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  wins   Int @default(0)
  losses Int @default(0)
  draws  Int @default(0)

  currentWinStreak Int @default(0)
  topWinStreak     Int @default(0)

  // The daily check-in streak, counted in UTC calendar days by
  // @openchess/shared's `advanceStreak`. Zero for a player who has never
  // checked in, and never reset on a miss — the next check-in simply starts
  // again at one, so a lapsed streak reads as "1", not as a hole.
  currentLoginStreak Int @default(0)
  topLoginStreak     Int @default(0)

  // The last day claimed. Date-typed rather than a timestamp on purpose: this
  // doubles as the idempotency key for the day's payout, and a conditional
  // write against `lastCheckInDay < today` is what stops two concurrent
  // check-ins from paying twice. A timestamp would make that a range query and
  // the guard would stop being exact.
  lastCheckInDay DateTime? @db.Date

  rating Int @default(1200)

  // The puzzle ladder, kept apart from `rating` on purpose: solving tactics and
  // winning games are different skills, and one number for both would let a
  // player farm either side of it into a rank they cannot hold.
  puzzleRating Int @default(1000)

  puzzlesSolved   Int @default(0)
  puzzlesAttempted Int @default(0)

  currentPuzzleStreak Int @default(0)
  topPuzzleStreak     Int @default(0)

  updatedAt DateTime @updatedAt

  @@index([rating(sort: Desc)])
  @@index([wins(sort: Desc)])
  @@index([puzzleRating(sort: Desc)])
}

enum GameMode {
  AI
  PVP
}

enum GameResult {
  WHITE_WIN
  BLACK_WIN
  DRAW
  ABORTED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Game {
  id   String   @id @default(cuid())
  mode GameMode

  // UCI ("e2e4", "e7e8q"), appended one per ply — the format `fromRecord` in
  // @openchess/shared replays. Replaying is what reconstructs the repetition map
  // and the fifty-move clock; a FEN alone cannot carry position history, so
  // `draw-repetition` would never fire if this were the cache and not the record.
  moves      String[]

  // Denormalized cache of the position after the last ply. Lets a
  // read hit the board without replaying; never the source of truth.
  currentFen String?

  // AI games need a strength. Rewards scale off it.
  difficulty Difficulty?

  // Null on whichever side the bot is playing in an AI game.
  whitePlayerId String?
  blackPlayerId String?
  whitePlayer   User?   @relation("WhitePlayer", fields: [whitePlayerId], references: [id], onDelete: SetNull)
  blackPlayer   User?   @relation("BlackPlayer", fields: [blackPlayerId], references: [id], onDelete: SetNull)

  result   GameResult?
  pgn      String?
  finalFen String?

  // Time control. Null on an untimed game — the current default — and both set
  // together otherwise, naming a preset in @openchess/shared by its numbers.
  initialSeconds   Int?
  incrementSeconds Int?

  // Remaining time per side, in milliseconds, as of the last committed move.
  // The clock of the side to move is still running against `turnStartedAt`; a
  // reader ticks it down from there rather than trusting these verbatim. Null
  // exactly when the game is untimed.
  whiteTimeMs Int?
  blackTimeMs Int?

  // When the side-to-move's clock started running: the last move's commit, or
  // the game's start before the first move. Null on an untimed game.
  turnStartedAt DateTime?

  startedAt DateTime  @default(now())
  endedAt   DateTime?

  // Guards against paying a game out twice if the finish request is retried.
  rewardsGranted Boolean @default(false)

  transactions CoinTransaction[]

  // The challenge this game was created from, when it was not created by the
  // matchmaking queue. One game per challenge; see `Challenge.gameId`.
  challenge Challenge?

  @@index([whitePlayerId, endedAt(sort: Desc)])
  @@index([blackPlayerId, endedAt(sort: Desc)])
  // The spectator list: live PvP games, newest first. Partial on `mode` is not
  // expressible here, so the index carries it as a leading column instead.
  @@index([mode, endedAt, startedAt(sort: Desc)])
}

model Achievement {
  id String @id @default(cuid())

  // Stable key that server logic references ("FIRST_WIN"). Never key off `name`,
  // which is display copy and will get reworded.
  code        String  @unique
  name        String
  description String
  iconUrl     String?

  // Paid on unlock, on top of the normal per-game payout.
  xpReward   Int @default(0)
  coinReward Int @default(0)

  // Hidden from the achievement list until unlocked.
  secret Boolean @default(false)

  createdAt DateTime @default(now())

  unlockedBy UserAchievement[]
}

model UserAchievement {
  id            String @id @default(cuid())
  userId        String
  achievementId String

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  unlockedAt DateTime @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

enum TitleRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

model Title {
  id String @id @default(cuid())

  code        String  @unique // "GRANDMASTER"
  label       String // "Grandmaster"
  description String?

  price         Int
  rarity        TitleRarity @default(COMMON)
  requiredLevel Int         @default(1)

  // False for titles handed out as achievement rewards rather than store stock.
  isPurchasable Boolean @default(true)

  createdAt DateTime @default(now())

  ownedBy    UserTitle[]
  equippedBy User[]      @relation("EquippedTitle")
}

model UserTitle {
  id      String @id @default(cuid())
  userId  String
  titleId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title Title @relation(fields: [titleId], references: [id], onDelete: Cascade)

  purchasedAt DateTime @default(now())

  // Snapshot of what they actually paid; store prices change over time.
  pricePaid Int

  @@unique([userId, titleId])
  @@index([userId])
}

enum CoinReason {
  GAME_REWARD
  ACHIEVEMENT
  PURCHASE
  ADMIN_GRANT
  DAILY_STREAK
  PUZZLE
}

model CoinTransaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount Int // positive = earned, negative = spent
  reason CoinReason

  gameId String?
  game   Game?   @relation(fields: [gameId], references: [id], onDelete: SetNull)

  balanceAfter Int
  createdAt    DateTime @default(now())

  // Postgres treats NULLs as distinct, so this only constrains rows that carry a
  // gameId: one GAME_REWARD per user per game, while purchases stay unbounded.
  // Puzzle payouts carry no gameId and are guarded instead by the one-row-per
  // -player-per-puzzle constraint on PuzzleAttempt, in the same transaction.
  @@unique([userId, gameId, reason])
  @@index([userId, createdAt(sort: Desc)])
}

/**
 * A tactics puzzle: a position, and the line that refutes it.
 *
 * `moves` follows the Lichess convention the importer and @openchess/shared
 * both speak — `fen` is the position *before* the mistake, `moves[0]` is the
 * mistake, and the solver plays the odd indices from there. See
 * `chess/puzzle.ts`.
 */
model Puzzle {
  id String @id @default(cuid())

  // The key in the corpus this row came from ("00sHx" for a Lichess puzzle), so
  // a re-import rewrites a puzzle in place instead of duplicating it. Rows
  // authored here carry their own stable key rather than a generated one.
  externalId String @unique

  fen   String
  moves String[]

  // On the same Elo scale players are rated on, which is what makes serving a
  // puzzle "near your rating" mean anything.
  rating Int

  // Tactical motifs — "fork", "backRankMate", "mateIn2". Free-form, and only
  // used for display and filtering.
  themes String[]

  /// Where the position came from, when the corpus records it.
  sourceUrl String?

  /// Counters for the catalog view. Neither is load-bearing.
  plays  Int @default(0)
  solves Int @default(0)

  /// The UTC day this puzzle is the daily one for. At most one puzzle per day;
  /// the unique index is what makes assigning it idempotent under a race.
  dailyOn DateTime? @unique @db.Date

  createdAt DateTime @default(now())

  attempts PuzzleAttempt[]

  // The serving query is "a puzzle near this rating I have not attempted".
  @@index([rating])
}

model PuzzleAttempt {
  id       String @id @default(cuid())
  userId   String
  puzzleId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  puzzle Puzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  solved   Boolean
  hintUsed Boolean @default(false)

  /// How long the solve took, when the client reports it.
  msSpent Int?

  ratingBefore Int
  ratingAfter  Int

  xpAwarded    Int @default(0)
  coinsAwarded Int @default(0)

  createdAt DateTime @default(now())

  // One scored attempt per player per puzzle. This is the idempotency key for
  // the payout — a retried submission collides here rather than paying twice —
  // and it is also what stops the same puzzle being farmed for coins. Replaying
  // a puzzle you have already attempted is allowed; it just pays nothing.
  @@unique([userId, puzzleId])
  @@index([userId, createdAt(sort: Desc)])
}

enum ChallengeStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

enum ChallengeColor {
  WHITE
  BLACK
  RANDOM
}

/// The clock a challenge is played on, naming a preset in @openchess/shared.
enum ClockPreset {
  BULLET
  BLITZ
  RAPID
}

/**
 * A direct invitation to play, as opposed to the anonymous pairing the
 * matchmaking queue does. Either addressed to a named player, or open — anyone
 * holding the `code` can accept it.
 */
model Challenge {
  id String @id @default(cuid())

  /// Short, human-typeable, unique: what one player reads out to another.
  code String @unique

  challengerId String
  challenger   User   @relation("Challenger", fields: [challengerId], references: [id], onDelete: Cascade)

  /// Null on an open challenge, which the code alone admits you to.
  challengedId String?
  challenged   User?   @relation("Challenged", fields: [challengedId], references: [id], onDelete: Cascade)

  /// The side the challenger asked for. RANDOM is drawn when the game is made.
  color ChallengeColor @default(RANDOM)

  /// Null for an untimed game.
  clock ClockPreset?

  status ChallengeStatus @default(PENDING)

  /// The game this became, once accepted. Unique: one challenge, one game.
  gameId String? @unique
  game   Game?   @relation(fields: [gameId], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  /// After this the challenge is dead whatever its status says; the accept path
  /// checks the clock rather than relying on a sweeper having run.
  expiresAt   DateTime
  respondedAt DateTime?

  // The two list queries: what is waiting for me, and what am I waiting on.
  @@index([challengedId, status, createdAt(sort: Desc)])
  @@index([challengerId, status, createdAt(sort: Desc)])
}
