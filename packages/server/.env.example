NODE_ENV=development
PORT=9999
LOG_LEVEL=debug

DATABASE_URL=file:local.db
# Required when NODE_ENV=production.
DATABASE_AUTH_TOKEN=

ALLOWED_ORIGINS=https://openchess.example

CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# The client_id of our own Clerk OAuth application. Required in production, so
# that access tokens minted for some other OAuth app on the same Clerk instance
# are rejected instead of being honored against this API.
CLERK_OAUTH_CLIENT_ID=
