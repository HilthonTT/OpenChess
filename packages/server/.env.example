NODE_ENV=development
PORT=9999
LOG_LEVEL=debug

DATABASE_URL=file:local.db
# Required when NODE_ENV=production.
DATABASE_AUTH_TOKEN=

ALLOWED_ORIGINS=https://openchess.example

# The public origin this API is served on. Used to build the URL Polar returns
# the customer to after checkout, so it must be the real externally-reachable
# origin, not an internal one. Defaults to http://localhost:$PORT outside
# production; required when NODE_ENV=production.
PUBLIC_BASE_URL=

CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# The client_id of our own Clerk OAuth application. Required in production, so
# that access tokens minted for some other OAuth app on the same Clerk instance
# are rejected instead of being honored against this API.
CLERK_OAUTH_CLIENT_ID=

# Leave blank to run without Sentry: no DSN, no error reporting, no tracing.
SENTRY_DSN=
# Fraction of requests traced, 0 to 1. 1 sends a transaction for every request,
# which is fine locally but will burn a production quota quickly.
SENTRY_TRACES_SAMPLE_RATE=1

# All four are required to boot. Get them from the Polar dashboard for the
# environment named by POLAR_SERVER — sandbox and production have separate
# tokens, products and meters, and IDs from one do not resolve in the other.
POLAR_ACCESS_TOKEN=dev
POLAR_PRODUCT_ID=test
POLAR_CREDITS_METER_ID=test
# 'sandbox' (play money) or 'production' (real charges). Must be 'production'
# when NODE_ENV=production, or the server refuses to start.
POLAR_SERVER=sandbox
INNGEST_DEV=1
